NODE_ENV=development
PORT=3000
APP_PUBLIC_URL=http://localhost:3000
SESSION_SECRET=change-this-to-at-least-32-random-characters

# Stripe is optional for local development, required for real checkout.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Store settings
CURRENCY=eur
SHIPPING_FLAT_CENTS=500
FREE_SHIPPING_THRESHOLD_CENTS=15000
TAX_RATE=0.20

# Local-only fallback. Keep false in production.
ALLOW_DEMO_CHECKOUT=true
